{
  "info": {
    "_postman_id": "dc2b8dc6-eadf-46c8-b92a-78695b525562",
    "name": "Bill Calculator",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "47893985"
  },
  "item": [
    {
      "name": "Automation script",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Check the response status code is as expected.",
              "pm.test(\"Status code validation\", function () {",
              "console.log(\"Validating Status Code for:\",pm.iterationData.get(\"Test Area\"));",
              "pm.response.to.have.status(Number(pm.iterationData.get(\"Expected_StatusCode\"))",
              ");",
              "});",
              "console.log(\"Expected status is correct.\");",
              "",
              "let jsonData = pm.response.json();",
              "",
              "// Check whether the Total Tax is correct",
              "let expectedTotalTax = pm.iterationData.get(\"Total_Tax\");",
              "if (expectedTotalTax) {",
              "pm.test(\"Check the Total Tax\", function () {",
              "let totalTax =",
              "jsonData.bill.billBreakDown.taxes",
              ".reduce((sum, item) => sum + Number(item.amount), 0);",
              "",
              "pm.expect(totalTax)",
              ".to.eql(Number(expectedTotalTax));",
              "",
              "console.log(\"Total Tax is matching:\",",
              "totalTax);",
              "});",
              "}",
              "",
              "// Check whether the Total Amount is correct",
              "let expectedTotalAmount = pm.iterationData.get(\"Total_Amount\");",
              "if (expectedTotalAmount) {",
              "pm.test(\"Total Amount is correct\", function () {",
              "pm.expect(jsonData.bill.billBreakDown.thisBillAmount).to.eql(Number(expectedTotalAmount));",
              "console.log(\"Total Amount is matching:\",jsonData.bill.billBreakDown.thisBillAmount);",
              "});",
              "}",
              "",
              "// Check whether the Brought Forward is correct",
              "let expectedBroughtForward = pm.iterationData.get(\"Brought_Forwards\");",
              "if (expectedBroughtForward) {",
              "pm.test(\"Total Brought Forward is correct\", function () {",
              "let totalBroughtForward = (jsonData.bill.broughtForwards || [])",
              ".reduce((sum, item) => sum + Number(item.units), 0);",
              "pm.expect(totalBroughtForward).to.eql(Number(expectedBroughtForward));",
              "",
              "console.log(\"Total Brought Forward is matching:\",totalBroughtForward);",
              "});",
              "}",
              "",
              "// Check whether the Carry Forward is correct",
              "let expectedCarryForward = pm.iterationData.get(\"carryForwards\");",
              "if (expectedCarryForward) {",
              "pm.test(\"Total Carry Forward is correct\", function () {",
              "let totalCarryForward = (jsonData.bill.carryForwards || [])",
              ".reduce((sum, item) => sum + Number(item.units), 0);",
              "pm.expect(totalCarryForward).to.eql(Number(expectedCarryForward));",
              "",
              "console.log(\"Total Carry Forward is matching:\",totalCarryForward);",
              "});",
              "}",
              "",
              "// Check whether the Generation details are correct",
              "",
              "// Helper to convert CSV comma string to array",
              "function getArray(fieldName) {",
              "let value = pm.iterationData.get(fieldName);",
              "if (!value) return [];",
              "return value.toString()",
              ".replace(/\"/g,'')",
              ".split(\",\")",
              ".map(v => v.trim());",
              "}",
              "",
              "//This will return the set of Generation details and if its emplty it will return [] empty array.",
              "let actualGenerations = jsonData.bill.billBreakDown.generation || [];",
              "",
              "let expectedGenUnits = getArray(\"GenerationUnits\");",
              "let expectedGenRates = getArray(\"GenerationRate\");",
              "let expectedGenAmounts = getArray(\"GenTotalPrice\");",
              "",
              "if (expectedGenUnits.length === 0) {",
              "//If Generations are [] it will show the follwing message and will not execute anything below.",
              "pm.test(\"Generation should be empty\", function () {",
              "pm.expect(actualGenerations.length).to.eql(0);",
              "});",
              "",
              "}",
              "else {",
              "//If Generations are available it will execute the rest of the code.",
              "pm.test(\"Generation count is correct\", function () {",
              "pm.expect(actualGenerations.length)",
              ".to.eql(expectedGenUnits.length);",
              "});",
              "console.log(\"Entering Generation validation section\");",
              "for (let i = 0; i < expectedGenUnits.length; i++) {",
              "",
              "pm.test(`Generatoin ${i+1} - Units`, function () {",
              "pm.expect(Number(actualGenerations[i].units))",
              ".to.eql(Number(expectedGenUnits[i]));",
              "});",
              "",
              "pm.test(`Generation ${i+1} - Rate`, function () {",
              "pm.expect(Number(actualGenerations[i].rate))",
              ".to.eql(Number(expectedGenRates[i]));",
              "});",
              "",
              "pm.test(`Generation ${i+1} - Amount`, function () {",
              "pm.expect(Number(actualGenerations[i].amount))",
              ".to.eql(Number(expectedGenAmounts[i]));",
              "});",
              "}",
              "console.log(\"Generation section is matching:\",expectedGenAmounts);",
              "}",
              "",
              "// Helper to convert CSV string to array of numbers (handles quotes)",
              "function parseNumberArray(str, outerSep = \"|\", innerSep = \",\") {",
              "if (!str) return [];",
              "return str.split(outerSep).map(s =>",
              "s.replace(/\"/g, '').trim()",
              ".split(innerSep)",
              ".map(v => Number(v.trim()))",
              ");",
              "}",
              "",
              "// Helper to convert CSV string to array of strings (handles quotes)",
              "function parseStringArray(str, outerSep = \"|\", innerSep = \",\") {",
              "if (!str) return [];",
              "return str.split(outerSep).map(s =>",
              "s.replace(/\"/g, '').trim()",
              ".split(innerSep)",
              ".map(v => v.trim())",
              ");",
              "}",
              "",
              "// ---------- SAFE CSV HELPERS ----------",
              "",
              "function clean(value){",
              "    if(!value) return \"\";",
              "    return value.toString().replace(/\"/g,\"\").trim();",
              "}",
              "",
              "function parseUnits(value){",
              "    value = clean(value);",
              "    if(!value) return [];",
              "    return value.split(\"|\").map(v => Number(v.trim()));",
              "}",
              "",
              "function parseSlabs(value){",
              "    value = clean(value);",
              "    if(!value) return [];",
              "",
              "    // multiple consumptions (comma inside)",
              "    if(value.includes(\",\")){",
              "        return value.split(\"|\").map(x => x.split(\",\").map(v => v.trim()));",
              "    }",
              "",
              "    // single consumption multiple slabs",
              "    return [ value.split(\"|\").map(v => v.trim()) ];",
              "}",
              "",
              "function parseSlabsNum(value){",
              "    value = clean(value);",
              "    if(!value) return [];",
              "",
              "    if(value.includes(\",\")){",
              "        return value.split(\"|\").map(x => x.split(\",\").map(v => Number(v.trim())));",
              "    }",
              "",
              "    return [ value.split(\"|\").map(v => Number(v.trim())) ];",
              "}",
              "",
              "// ---------- PARSE CSV ----------",
              "",
              "let expectedUnitsArray = parseUnits(pm.iterationData.get(\"Total_Units\"));",
              "let expectedConsumptionArray = parseUnits(pm.iterationData.get(\"Consumption\"));",
              "",
              "let expectedSlabNamesArray = parseSlabs(pm.iterationData.get(\"slabName\"));",
              "let expectedSlabUnitsArray = parseSlabsNum(pm.iterationData.get(\"slabUnits\"));",
              "let expectedSlabRatesArray = parseSlabsNum(pm.iterationData.get(\"slabRates\"));",
              "let expectedSlabAmountsArray = parseSlabsNum(pm.iterationData.get(\"slabAmounts\"));",
              "",
              "// ---------- RESPONSE DATA ----------",
              "",
              "let consumptions = jsonData?.bill?.billBreakDown?.consumption || [];",
              "",
              "// ---------- CONSUMPTION COUNT ----------",
              "",
              "pm.test(\"Consumption count is correct\", function () {",
              "",
              "    if(expectedUnitsArray.length === 0){",
              "        pm.expect(consumptions.length).to.be.at.least(0);",
              "    }",
              "    else{",
              "        pm.expect(consumptions.length).to.eql(expectedUnitsArray.length);",
              "    }",
              "",
              "});",
              "",
              "// ---------- CONSUMPTION VALIDATION ----------",
              "",
              "consumptions.forEach((cons, index) => {",
              "",
              "    if(expectedUnitsArray.length){",
              "        pm.test(`Consumption ${index+1} Units`, function () {",
              "            pm.expect(Number(cons.units)).to.eql(expectedUnitsArray[index]);",
              "        });",
              "    }",
              "",
              "    if(expectedConsumptionArray.length){",
              "        pm.test(`Consumption ${index+1} Amount`, function () {",
              "            pm.expect(Number(cons.amount)).to.eql(expectedConsumptionArray[index]);",
              "        });",
              "    }",
              "",
              "    // ---------- SLAB VALIDATION ----------",
              "",
              "    let actualSlabs = cons.slabs || [];",
              "",
              "    let expectedSlabsNames = expectedSlabNamesArray[index] || [];",
              "    let expectedSlabsUnits = expectedSlabUnitsArray[index] || [];",
              "    let expectedSlabsRates = expectedSlabRatesArray[index] || [];",
              "    let expectedSlabsAmounts = expectedSlabAmountsArray[index] || [];",
              "",
              "    pm.test(`Consumption ${index+1} Slab Count`, function () {",
              "        pm.expect(actualSlabs.length).to.eql(expectedSlabsNames.length);",
              "    });",
              "",
              "    actualSlabs.forEach((slab, sIndex) => {",
              "",
              "        pm.test(`Consumption ${index+1} Slab ${sIndex+1} Name`, function () {",
              "            pm.expect(slab.slab).to.eql(expectedSlabsNames[sIndex]);",
              "        });",
              "",
              "        pm.test(`Consumption ${index+1} Slab ${sIndex+1} Units`, function () {",
              "            pm.expect(Number(slab.units)).to.eql(expectedSlabsUnits[sIndex]);",
              "        });",
              "",
              "        pm.test(`Consumption ${index+1} Slab ${sIndex+1} Rate`, function () {",
              "            pm.expect(Number(slab.rate)).to.eql(expectedSlabsRates[sIndex]);",
              "        });",
              "",
              "        pm.test(`Consumption ${index+1} Slab ${sIndex+1} Amount`, function () {",
              "            pm.expect(Number(slab.amount)).to.eql(expectedSlabsAmounts[sIndex]);",
              "        });",
              "",
              "    });",
              "",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "function getArray(fieldName) {",
              "    let value = pm.iterationData.get(fieldName);",
              "",
              "    if (!value) return []; // handle empty or undefined",
              "",
              "    return value.toString().split(\",\").map(v => v.trim());",
              "}",
              "",
              "let registerValues = getArray(\"registerValues\");",
              "let previousReadings = getArray(\"previousReadings\");",
              "let currentReadings = getArray(\"currentReadings\");",
              "let prevDates = getArray(\"prevDates\");",
              "let currDates = getArray(\"currDates\");",
              "",
              "let readingsArray = [];",
              "",
              "for (let i = 0; i < registerValues.length; i++) {",
              "    readingsArray.push({",
              "        meterSerial: pm.collectionVariables.get(\"meterSerial\"),",
              "        meterStatus: pm.iterationData.get(\"meterStatus\"),",
              "        registerValue: registerValues[i],",
              "        previousReading: parseFloat(previousReadings[i] || 0),",
              "        previousReadingDate: prevDates[i] || \"\",",
              "        currentReading: parseFloat(currentReadings[i] || 0),",
              "        currentReadingDate: currDates[i] || \"\",",
              "        readingOnTariffChange: 0,",
              "        tarriffChangeReadingDate: \"\",",
              "        isMeterTurnOver: false",
              "    });",
              "}",
              "",
              "// Submit Brought Forwards",
              "let broughtForwardUnits = pm.iterationData.get(\"broughtForwards\");",
              "",
              "let broughtForwardsArray = [];",
              "",
              "if (broughtForwardUnits) {",
              "    broughtForwardsArray.push({",
              "        type: \"NetMetering\",",
              "        units: Number(broughtForwardUnits)",
              "    });",
              "}",
              "",
              "// Set variables",
              "pm.variables.set(\"dynamicReadings\", JSON.stringify(readingsArray));",
              "pm.variables.set(\"dynamicBroughtForwards\", JSON.stringify(broughtForwardsArray));",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"billId\": \"{{billId}}\",\n    \"accountNo\": \"{{accountNo}}\",\n    \"tariffCategory\": \"{{tariffCategory}}\",\n    \"genTariffCategory\": \"{{genTariffCategory}}\",\n    \"readingOnTariffChangeAvailable\": false,\n    \"broughtForwards\": {{dynamicBroughtForwards}},\n    \"readings\": {{dynamicReadings}}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "192.168.2.39:5000/api/bill-calculation",
          "host": [
            "192",
            "168",
            "2",
            "39"
          ],
          "port": "5000",
          "path": [
            "api",
            "bill-calculation"
          ]
        }
      },
      "response": []
    }
  ],
